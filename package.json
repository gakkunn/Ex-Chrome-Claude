{
  "name": "claude_power_suite",
  "version": "1.5.2",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:watch",
    "dev:watch": "vite build --watch --mode development",
    "dev:serve": "vite",
    "build": "vite build",
    "preview": "vite preview --host",
    "lint": "eslint --max-warnings=0 --config config/eslint.config.mjs \"src/**/*.{ts,tsx}\"",
    "lint:fix": "eslint --fix --config config/eslint.config.mjs \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"{src,config,scripts}/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"{src,config,scripts}/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "check": "npm run lint && npm run format:check",
    "prepare": "husky install"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "preact": "^10.25.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@eslint/js": "^10.0.1",
    "@preact/preset-vite": "^2.10.5",
    "@types/chrome": "^0.0.260",
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8"
  },
  "overrides": {
    "@crxjs/vite-plugin": {
      "rollup": "2.80.0",
      "@rollup/pluginutils": {
        "picomatch": "2.3.2"
      }
    },
    "flatted": "3.4.2",
    "micromatch": {
      "picomatch": "2.3.2"
    },
    "yaml": "2.8.3"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings=0 --config config/eslint.config.mjs"
    ],
    "*.{ts,tsx,js,jsx,json,css,md}": [
      "prettier --write"
    ]
  }
}
